# ─── Team invite emails (optional) ─────────────────────────────────
# Generic SMTP — works with Gmail, SendGrid, Postmark, Resend's SMTP relay,
# or your own mail server. Leave blank to skip email sending entirely —
# adding someone to the team still grants access immediately either way;
# this only controls whether they also get notified by email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Database ────────────────────────────────────────────────────
# Postgres connection string (Supabase/Neon/Render Postgres/etc).
DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_SSL=true

# ─── App ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Your real deployed URL (e.g. https://your-app.onrender.com) — no
# trailing slash. Required for ACC webhook registration; leave as
# localhost until you've deployed, since ACC can't call your laptop.
PUBLIC_BASE_URL=http://localhost:3000

# ─── Automatic re-sync of LINKED issues (every 2 min by default) ───
# This does NOT push new/unlinked issues automatically — only issues you've
# already chosen to link via the UI. Set to false to disable entirely.
POLL_ENABLED=true
POLL_CRON=*/2 * * * *

# ─── Autodesk Platform Services (APS / ACC) ───────────────────────
APS_CLIENT_ID=
APS_CLIENT_SECRET=
# Must exactly match the callback URL registered in your APS app.
# Use your real hosted URL in production, not localhost.
APS_CALLBACK_URL=http://localhost:3000/auth/acc/callback

# ─── Revizto ─────────────────────────────────────────────────────
# Nothing needed here — Revizto has no client credentials or webhook
# system. Auth is per-user via access code (see the app's Connections
# page), and Revizto-side updates are pulled via API calls (on-demand
# button or the optional poller below), not pushed to us.

# ─── ACC webhook verification ─────────────────────────────────────
# Secret used to verify that calls to /webhook/acc genuinely came from
# Autodesk (ACC has webhooks; Revizto does not — this has nothing to do
# with Revizto). Signature check is not yet implemented (see README).
WEBHOOK_SECRET=
